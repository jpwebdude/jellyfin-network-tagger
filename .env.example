# ─── Jellyfin Network Tagger — Example Environment File ─────────────────────
# Copy this file to .env and fill in your own values.
# ─────────────────────────────────────────────────────────────────────────────


# Full URL to your Jellyfin server.
# From inside Docker, use your host machine's LAN IP — not localhost.
JELLYFIN_URL=http://192.168.X.X:8096

# Jellyfin API key — Dashboard → API Keys → + (name it "tagger")
JELLYFIN_API_KEY=your-jellyfin-api-key-here

# TMDB Read Access Token — NOT the short API key.
# Get it at: themoviedb.org → Settings → API → READ ACCESS TOKEN (starts with eyJ...)

TMDB_API_KEY=eyJ...your-tmdb-read-access-token-here


# Two-letter country code for streaming availability lookup.
# Default: US
TMDB_COUNTRY=US

# How often to re-scan the library (in hours).
# Default: 24
RUN_INTERVAL_HOURS=24

# Set to "true" to preview what WOULD be tagged without writing anything to Jellyfin.
# Always start with true, review the logs, then switch to false when ready.

# Default: false
DRY_RUN=true

# Comma-separated list of provider names to skip (exact TMDB names).
# Useful for filtering out free/ad-supported services or just networks you don't care about.

IGNORE_PROVIDERS=Tubi TV,Pluto TV,Crackle,The Roku Channel,Kanopy,BBC America,fuboTV,Philo,Fawesome,FlixFling,Hoopla,Kanopy,The Roku Channel,Philo,Fandango at Home Free,YouTube TV,Plex,TBS,tru TV,TNT,The CW,Xumo Play,Sundance Now,History Vault,Screambox Amazon Channel,YOW.tv,Hidive Amazon Channel,HiDive,MovieSphere+ Amazon Channel,DistroTV,Sling TV Orange and Blue,Shudder,Magnolia Selects Amazon Channel,Shout! Factory Amazon Channel,Shout! Factory TV,BFI Player Amazon Channel,Bloodstream,Fandor Amazon Channel,Midnight Pulp Amazon Channel,Sony Pictures Core Amazon Channel,Wonder Project Amazon Channel,Cineverse Amazon Channel,Night Flight Plus,Criterion Channel,Freeform,Broadway HD Amazon Channel,Broadway HD Amazon Channel
